# ─────────────────────────────────────────────────────────────
# ScaleFlow Academy — two-flow checkout environment
# Copy to .env.local (gitignored) and fill in. Set the same vars in
# Vercel (Preview + Production). NEXT_PUBLIC_* are exposed to the browser;
# everything else is server-only — keep secret.
# ─────────────────────────────────────────────────────────────

# ── Site ──
NEXT_PUBLIC_SITE_URL=https://academy.scaleflow.digital

# ── Clerk (auth) ──  https://dashboard.clerk.com → API Keys
# Enable Google as a social connection in Clerk → User & Authentication → SSO.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
# Send users to our gate, not Clerk's hosted pages:
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/checkout
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/checkout

# ── Telegram (login bridge + community + delivery) ──  @BotFather
# Public bot username (no @) for the Login Widget:
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=ScaleFlowAcademyBot
# Server-only bot token — verifies the login hash AND DMs buyers:
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Private community channel/group the bot can invite to (bot must be admin).
# Numeric chat id (e.g. -1001234567890) used to mint single-use invite links:
TELEGRAM_COMMUNITY_CHAT_ID=-1001234567890

# ── Whop (foreign card payments — embedded) ──  https://whop.com → your app
# Plan id for the foreign/card plan (NOT secret — ships in the embed):
NEXT_PUBLIC_WHOP_PLAN_ID=plan_xxxxxxxx

# ── n8n (existing backend: lead capture + grant) ──
N8N_BASE_URL=https://n8n.scaleflow.digital
# Server posts the order here (forwards multipart incl. receipt → Drive + Sheet).
# Defaults to N8N_BASE_URL + /webhook/scaleflow-checkout if unset.
N8N_LEAD_WEBHOOK_URL=https://n8n.scaleflow.digital/webhook/scaleflow-checkout
# Optional shared secret sent as `x-sf-internal` header so n8n webhooks can
# verify the call came from our server (set the same value in n8n):
N8N_INTERNAL_SECRET=change-me-long-random

# ── Google Sheets (server-side READ for the order-status page) ──
# Create a Google Cloud service account, enable the Sheets API, download the
# JSON key, and SHARE the leads Sheet with the service-account email (Viewer).
LEADS_SHEET_ID=18wpzvyLnxncIFCb18Qp3-3gavazWd4BPBwg2sA3jUmw
LEADS_SHEET_TAB=leads
GOOGLE_SERVICE_ACCOUNT_EMAIL=sf-academy-reader@your-project.iam.gserviceaccount.com
# Paste the private_key from the JSON with literal \n for newlines, in quotes:
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
